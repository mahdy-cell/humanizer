# Ensure consistent line endings across platforms
* text=auto

# Shell scripts must always use LF (Unix) line endings
*.sh text eol=lf

# Windows batch files must use CRLF
*.bat text eol=crlf

# Python files use LF
*.py text eol=lf

# YAML files use LF
*.yaml text eol=lf
*.yml text eol=lf

# Treat binary files correctly
*.png binary
*.jpg binary
*.pdf binary
*.docx binary
